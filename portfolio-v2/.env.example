# ---- Database (libSQL / SQLite) ----
# Local dev: a plain file works. Production: your Fly.io sqld URL.
DATABASE_URL="file:local.db"
# DATABASE_URL="libsql://<your-app>.fly.dev"
# DATABASE_AUTH_TOKEN="<token if your sqld requires auth>"

# ---- Admin auth ----
# The password you type at /admin/login
ADMIN_PASSWORD="change-me"
# Secret used to sign the session cookie (use a long random string)
AUTH_SECRET="generate-a-long-random-string"

# ---- Image uploads (Vercel Blob) ----
# Create a Blob store in the Vercel dashboard; it provides this token.
BLOB_READ_WRITE_TOKEN=""
